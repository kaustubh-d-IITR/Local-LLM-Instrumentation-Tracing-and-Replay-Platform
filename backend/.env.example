# PostgreSQL connection URI
SQLALCHEMY_DATABASE_URI=postgresql://user:password@db/telemetry_db

# Telemetry Toggles
ENABLE_LATENCY=True
ENABLE_ACTIVATIONS=True
ENABLE_ANOMALIES=True

# Thresholds for Anomaly Engine
MAX_ACTIVATION_THRESHOLD=50.0
MAX_LATENCY_THRESHOLD_MS=100.0
MEMORY_WARNING_THRESHOLD_PERCENT=90.0

# Sampling Rate (0.0 to 1.0)
TELEMETRY_SAMPLE_RATE=1.0

# HuggingFace Cache Directory (Docker Mounted)
HF_HOME=/root/.cache/huggingface
